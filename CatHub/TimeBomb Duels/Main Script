    thumbGlow.Parent = thumb
    AddCorner(thumbGlow, UDim.new(1, 0))

    local sliding = false
    local currentValue = default

    local function UpdateSlider(inputPos)
        local rel = math.clamp((inputPos.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        currentValue = math.floor(min + (max - min) * rel)
        rel = (currentValue - min) / (max - min)
        fill.Size = UDim2.new(rel, 0, 1, 0)
        thumb.Position = UDim2.new(rel, -8, 0.5, -8)
        valueLabel.Text = tostring(currentValue) .. (suffix or "")
        pcall(callback, currentValue)
    end

    local trackBtn = Instance.new("TextButton")
    trackBtn.BackgroundTransparency = 1
    trackBtn.Size = UDim2.new(1, 0, 1, 12)
    trackBtn.Position = UDim2.new(0, 0, 0, -6)
    trackBtn.Text = ""
    trackBtn.ZIndex = 8
    trackBtn.Parent = track

    trackBtn.MouseButton1Down:Connect(function()
        sliding = true
        thumbGlow.Visible = true
        UpdateSlider(UserInputService:GetMouseLocation())
    end)

    local moveConn = UserInputService.InputChanged:Connect(function(input)
        if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement
                        or input.UserInputType == Enum.UserInputType.Touch) then
            UpdateSlider(input.Position)
        end
    end)
    table.insert(State.Connections, moveConn)

    local upConn = UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
           or input.UserInputType == Enum.UserInputType.Touch then
            sliding = false
            thumbGlow.Visible = false
        end
    end)
    table.insert(State.Connections, upConn)

    trackBtn.MouseEnter:Connect(function()
        SafeTween(container, TweenInfo.new(Theme.AnimSpeedFast), {BackgroundColor3 = Theme.ButtonHover})
    end)
    trackBtn.MouseLeave:Connect(function()
        if not sliding then
            SafeTween(container, TweenInfo.new(Theme.AnimSpeedFast), {BackgroundColor3 = Theme.ButtonBg})
        end
    end)

    return container
end

