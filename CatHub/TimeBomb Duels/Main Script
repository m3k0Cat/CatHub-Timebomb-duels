do
    local dragging = false
    local dragStart, startPos

    TitleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
           or input.UserInputType == Enum.UserInputType.Touch then
            local mp = UserInputService:GetMouseLocation()
            local ca, cs = CloseBtn.AbsolutePosition, CloseBtn.AbsoluteSize
            local ma, ms = MinimizeBtn.AbsolutePosition, MinimizeBtn.AbsoluteSize
            if mp.X >= ca.X and mp.X <= ca.X + cs.X and mp.Y >= ca.Y and mp.Y <= ca.Y + cs.Y then return end
            if mp.X >= ma.X and mp.X <= ma.X + ms.X and mp.Y >= ma.Y and mp.Y <= ma.Y + ms.Y then return end
            dragging = true
            dragStart = input.Position
            startPos = MainFrame.Position
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
                         or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            local newPos = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X,
                                     startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            MainFrame.Position = newPos
            ShadowFrame.Position = UDim2.new(newPos.X.Scale, newPos.X.Offset - 30,
                                              newPos.Y.Scale, newPos.Y.Offset - 30)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
           or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

