function JumpSpoofer.DetectMatch()
    local inMatch = false
    pcall(function()
        local gui = LocalPlayer:FindFirstChild("PlayerGui")
        if gui then
            for _, child in ipairs(gui:GetDescendants()) do
                if child:IsA("TextLabel") or child:IsA("TextButton") then
                    local text = child.Text:lower()
                    if text:find("bomb") or text:find("duel") or text:find("match")
                       or text:find("round") or text:find("timer") or text:find("fight") then
                        inMatch = true
                        break
                    end
                end
            end
        end
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj.Name:lower():find("arena") or obj.Name:lower():find("match")
               or obj.Name:lower():find("bomb") or obj.Name:lower():find("duel") then
                inMatch = true
                break
            end
        end
        local char = LocalPlayer.Character
        if char then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then
                for _, obj in ipairs(workspace:GetDescendants()) do
                    if obj:IsA("BasePart") and obj.Name:lower():find("bomb") then
                        if (obj.Position - hrp.Position).Magnitude < 100 then
                            inMatch = true
                            break
                        end
                    end
                end
            end
        end
        if LocalPlayer.Team then inMatch = true end
    end)
    State.JumpSpoofer.IsInMatch = inMatch
    return inMatch
end

function JumpSpoofer.VelocityJump()
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not humanoid then return end
    local spoofer = State.JumpSpoofer
    local now = tick()
    if now - spoofer.LastJumpTime < spoofer.CooldownTime then return end
    spoofer.LastJumpTime = now
    pcall(function()
        local groundPos = JumpSpoofer.GetGroundPosition()
        if groundPos then
            spoofer.LastGroundPosition = groundPos
            spoofer.LastGroundCFrame = hrp.CFrame
        end
        if not spoofer.VelocitySmoother or not spoofer.VelocitySmoother.Parent then
            JumpSpoofer.CreateBodyMovers()
        end
        local bv = spoofer.VelocitySmoother
        if not bv then return end
        JumpSpoofer.SpoofHumanoidState()
        local jumpForce = spoofer.SpoofStrength
        bv.MaxForce = Vector3.new(0, math.huge, 0)
        bv.Velocity = Vector3.new(0, jumpForce, 0)
        if spoofer.GyroStabilizer then
            spoofer.GyroStabilizer.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
            spoofer.GyroStabilizer.CFrame = hrp.CFrame
        end
        JumpSpoofer.SuppressJumpAnimation()
        task.spawn(function()
            local startTime = tick()
            local duration = 0.35
            while tick() - startTime < duration do
                if not spoofer.Enabled then break end
                local elapsed = tick() - startTime
                local alpha = elapsed / duration
                local currentVel = jumpForce * (1 - alpha * alpha)
                if bv and bv.Parent then
                    bv.Velocity = Vector3.new(0, math.max(currentVel, 0), 0)
                end
                JumpSpoofer.SpoofHumanoidState()
                JumpSpoofer.SuppressJumpAnimation()
                JumpSpoofer.RecordPosition(hrp.Position)
                RunService.Heartbeat:Wait()
            end
            if bv and bv.Parent then
                local descentTime = tick()
                local descentDuration = 0.4
                while tick() - descentTime < descentDuration do
                    if not spoofer.Enabled then break end
                    local elapsed = tick() - descentTime
                    local alpha = elapsed / descentDuration
                    local descendVel = -jumpForce * 0.8 * alpha
                    if bv and bv.Parent then
                        bv.Velocity = Vector3.new(0, descendVel, 0)
                    end
                    JumpSpoofer.SpoofHumanoidState()
                    JumpSpoofer.SuppressJumpAnimation()
                    if JumpSpoofer.IsGrounded() then break end
                    RunService.Heartbeat:Wait()
                end
            end
            if bv and bv.Parent then
                bv.MaxForce = Vector3.new(0, 0, 0)
                bv.Velocity = Vector3.new(0, 0, 0)
            end
            if spoofer.GyroStabilizer and spoofer.GyroStabilizer.Parent then
                spoofer.GyroStabilizer.MaxTorque = Vector3.new(0, 0, 0)
            end
            JumpSpoofer.ForceGroundAnimation()
            spoofer.SpoofedJumps = spoofer.SpoofedJumps + 1
        end)
    end)
end

function JumpSpoofer.CFrameJump()
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not humanoid then return end
    local spoofer = State.JumpSpoofer
    local now = tick()
    if now - spoofer.LastJumpTime < spoofer.CooldownTime then return end
    spoofer.LastJumpTime = now
    pcall(function()
        local startPos = hrp.Position
        local jumpHeight = spoofer.SpoofStrength * 0.15
        JumpSpoofer.SpoofHumanoidState()
        task.spawn(function()
            local jumpDuration = 0.6
            local startTime = tick()
            while tick() - startTime < jumpDuration do
                if not spoofer.Enabled then break end
                local elapsed = tick() - startTime
                local alpha = elapsed / jumpDuration
                local heightOffset = -4 * jumpHeight * (alpha - 0.5) ^ 2 + jumpHeight
                local moveDir = humanoid.MoveDirection
                local lateralOffset = moveDir * elapsed * humanoid.WalkSpeed
                hrp.CFrame = CFrame.new(
                    startPos.X + lateralOffset.X,
                    startPos.Y + heightOffset,
                    startPos.Z + lateralOffset.Z
                ) * CFrame.Angles(0, math.atan2(-moveDir.X, -moveDir.Z), 0)
                hrp.Velocity = Vector3.new(hrp.Velocity.X, 0, hrp.Velocity.Z)
                JumpSpoofer.SpoofHumanoidState()
                JumpSpoofer.SuppressJumpAnimation()
                JumpSpoofer.RecordPosition(hrp.Position)
                RunService.RenderStepped:Wait()
            end
            local groundPos = JumpSpoofer.GetGroundPosition()
            if groundPos then
                hrp.CFrame = CFrame.new(hrp.Position.X, groundPos.Y + 3, hrp.Position.Z)
                    * (hrp.CFrame - hrp.CFrame.Position)
            end
            JumpSpoofer.ForceGroundAnimation()
            spoofer.SpoofedJumps = spoofer.SpoofedJumps + 1
        end)
    end)
end

function JumpSpoofer.HybridJump()
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not humanoid then return end
    local spoofer = State.JumpSpoofer
    local now = tick()
    if now - spoofer.LastJumpTime < spoofer.CooldownTime then return end
    spoofer.LastJumpTime = now
    pcall(function()
        JumpSpoofer.SpoofHumanoidState()
        if not spoofer.VelocitySmoother or not spoofer.VelocitySmoother.Parent then
            JumpSpoofer.CreateBodyMovers()
        end
        task.spawn(function()
            local bv = spoofer.VelocitySmoother
            if not bv then return end
            local jumpForce = spoofer.SpoofStrength
            local startPos = hrp.Position
            bv.MaxForce = Vector3.new(0, math.huge, 0)
            bv.Velocity = Vector3.new(0, jumpForce * 0.7, 0)
            if spoofer.GyroStabilizer then
                spoofer.GyroStabilizer.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
                spoofer.GyroStabilizer.CFrame = hrp.CFrame
            end
            JumpSpoofer.SuppressJumpAnimation()
            local ascentDuration = 0.25
            local startTime = tick()
            while tick() - startTime < ascentDuration do
                if not spoofer.Enabled then break end
                local alpha = (tick() - startTime) / ascentDuration
                bv.Velocity = Vector3.new(0, jumpForce * 0.7 * (1 - alpha), 0)
                JumpSpoofer.SpoofHumanoidState()
                JumpSpoofer.SuppressJumpAnimation()
                hrp.Velocity = Vector3.new(hrp.Velocity.X, 0, hrp.Velocity.Z)
                RunService.Heartbeat:Wait()
            end
            bv.MaxForce = Vector3.new(0, 0, 0)
            bv.Velocity = Vector3.new(0, 0, 0)
            local peakPos = hrp.Position
            local descentDuration = 0.3
            startTime = tick()
            while tick() - startTime < descentDuration do
                if not spoofer.Enabled then break end
                local alpha = (tick() - startTime) / descentDuration
                local targetY = peakPos.Y - (peakPos.Y - startPos.Y) * alpha
                hrp.CFrame = CFrame.new(hrp.Position.X, targetY, hrp.Position.Z)
                    * (hrp.CFrame - hrp.CFrame.Position)
                hrp.Velocity = Vector3.new(hrp.Velocity.X, 0, hrp.Velocity.Z)
                JumpSpoofer.SpoofHumanoidState()
                JumpSpoofer.SuppressJumpAnimation()
                if JumpSpoofer.IsGrounded() then break end
                RunService.Heartbeat:Wait()
            end
            if spoofer.GyroStabilizer and spoofer.GyroStabilizer.Parent then
                spoofer.GyroStabilizer.MaxTorque = Vector3.new(0, 0, 0)
            end
            JumpSpoofer.ForceGroundAnimation()
            spoofer.SpoofedJumps = spoofer.SpoofedJumps + 1
        end)
    end)
end

function JumpSpoofer.ExecuteJump()
    local spoofer = State.JumpSpoofer
    if not spoofer.Enabled then return end
    local method = spoofer.Method
    if method == "Velocity" then
        JumpSpoofer.VelocityJump()
    elseif method == "CFrame" then
        JumpSpoofer.CFrameJump()
    elseif method == "Hybrid" then
        JumpSpoofer.HybridJump()
    end
    spoofer.JumpCount = spoofer.JumpCount + 1
end

function JumpSpoofer.StartAntiDetectLoop()
    local spoofer = State.JumpSpoofer
    JumpSpoofer.StopAntiDetectLoop()

    spoofer.HeartbeatConnection = RunService.Heartbeat:Connect(function(dt)
        if not spoofer.Enabled then return end
        pcall(function()
            local char = LocalPlayer.Character
            if not char then return end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            if not hrp or not humanoid then return end
            if not JumpSpoofer.IsGrounded() then
                spoofer.AirTimeAccumulator = spoofer.AirTimeAccumulator + dt
                if spoofer.AirTimeAccumulator > spoofer.MaxSafeAirTime then
                    JumpSpoofer.SpoofHumanoidState()
                    JumpSpoofer.SuppressJumpAnimation()
                    if spoofer.AntiDetectLevel >= 2 then
                        hrp.Velocity = Vector3.new(
                            hrp.Velocity.X,
                            math.clamp(hrp.Velocity.Y, -10, 10),
                            hrp.Velocity.Z
                        )
                    end
                end
            else
                spoofer.AirTimeAccumulator = 0
                spoofer.LastGroundPosition = hrp.Position
                spoofer.LastGroundCFrame = hrp.CFrame
            end
            if math.random(1, 60) == 1 then
                JumpSpoofer.DetectMatch()
            end
        end)
    end)

    spoofer.SteppedConnection = RunService.Stepped:Connect(function()
        if not spoofer.Enabled then return end
        pcall(function()
            local char = LocalPlayer.Character
            if not char then return end
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            if not humanoid then return end
            if spoofer.AntiDetectLevel >= 2 then
                local currentState = humanoid:GetState()
                if currentState == Enum.HumanoidStateType.Jumping
                   or currentState == Enum.HumanoidStateType.Freefall then
                    humanoid:ChangeState(Enum.HumanoidStateType.Running)
                end
            end
        end)
    end)

    spoofer.RenderConnection = RunService.RenderStepped:Connect(function()
        if not spoofer.Enabled then return end
        pcall(function()
            JumpSpoofer.SuppressJumpAnimation()
        end)
    end)
end

function JumpSpoofer.StopAntiDetectLoop()
    local spoofer = State.JumpSpoofer
    pcall(function()
        if spoofer.HeartbeatConnection then spoofer.HeartbeatConnection:Disconnect(); spoofer.HeartbeatConnection = nil end
        if spoofer.SteppedConnection then spoofer.SteppedConnection:Disconnect(); spoofer.SteppedConnection = nil end
        if spoofer.RenderConnection then spoofer.RenderConnection:Disconnect(); spoofer.RenderConnection = nil end
    end)
end

function JumpSpoofer.HookRemotes()
    pcall(function()
        for _, remote in ipairs(ReplicatedStorage:GetDescendants()) do
            if remote:IsA("RemoteEvent") or remote:IsA("RemoteFunction") then
                local name = remote.Name:lower()
                if name:find("jump") or name:find("detect") or name:find("cheat")
                   or name:find("anticheat") or name:find("verify") or name:find("validate") then
                    -- Tracked for monitoring
                end
            end
        end
    end)
end

function JumpSpoofer.Enable()
    local spoofer = State.JumpSpoofer
    spoofer.Enabled = true
    pcall(function()
        local char = LocalPlayer.Character
        if not char then return end
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if humanoid then
            spoofer.OriginalJumpPower = humanoid.JumpPower
            humanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, false)
            humanoid.JumpPower = 0
            humanoid.JumpHeight = 0
        end
    end)
    JumpSpoofer.InitRayParams()
    JumpSpoofer.CreateFakeGround()
    JumpSpoofer.CreateBodyMovers()
    JumpSpoofer.StartAntiDetectLoop()
    JumpSpoofer.HookRemotes()
    JumpSpoofer.DetectMatch()
    spoofer.JumpCount = 0
    spoofer.SpoofedJumps = 0
    spoofer.AirTimeAccumulator = 0
end

function JumpSpoofer.Disable()
    local spoofer = State.JumpSpoofer
    spoofer.Enabled = false
    JumpSpoofer.StopAntiDetectLoop()
    JumpSpoofer.DestroyBodyMovers()
    pcall(function()
        if spoofer.FakeGroundPart then
            spoofer.FakeGroundPart:Destroy()
            spoofer.FakeGroundPart = nil
        end
    end)
    pcall(function()
        local char = LocalPlayer.Character
        if char then
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            if humanoid then
                humanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, true)
                humanoid:SetStateEnabled(Enum.HumanoidStateType.Freefall, true)
                humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, true)
                humanoid.JumpPower = spoofer.OriginalJumpPower
            end
        end
    end)
    pcall(function() workspace.Gravity = spoofer.OriginalGravity end)
    spoofer.PositionHistory = {}
end

function JumpSpoofer.OnCharacterAdded(character)
    if not State.JumpSpoofer.Enabled then return end
    local humanoid = character:WaitForChild("Humanoid", 5)
    if not humanoid then return end
    task.delay(0.5, function()
        if State.JumpSpoofer.Enabled then
            pcall(function()
                humanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, false)
                humanoid.JumpPower = 0
                humanoid.JumpHeight = 0
            end)
            JumpSpoofer.InitRayParams()
            JumpSpoofer.CreateBodyMovers()
        end
    end)
end

