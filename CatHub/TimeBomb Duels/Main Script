local function ShowNotification(message, duration, color)
    pcall(function()
        local notif = Instance.new("Frame")
        notif.BackgroundColor3 = Theme.TitleBar
        notif.BackgroundTransparency = 0.1
        notif.Size = UDim2.new(0, 320, 0, 48)
        notif.Position = UDim2.new(1, 330, 1, -65)
        notif.ZIndex = 100
        notif.BorderSizePixel = 0
        notif.Parent = ScreenGui
        AddCorner(notif, Theme.CornerRadiusSmall)
        AddStroke(notif, color or Theme.Accent, 1, 0.5)

        local nt = Instance.new("TextLabel")
        nt.BackgroundTransparency = 1
        nt.Size = UDim2.new(1, -16, 1, 0)
        nt.Position = UDim2.new(0, 8, 0, 0)
        nt.Font = Theme.Font
        nt.Text = message
        nt.TextColor3 = color or Theme.Accent
        nt.TextSize = 12
        nt.TextWrapped = true
        nt.ZIndex = 101
        nt.Parent = notif

        SafeTween(notif, TweenInfo.new(0.4, Enum.EasingStyle.Back), {
            Position = UDim2.new(1, -330, 1, -65),
        })
        task.delay(duration or 3, function()
            SafeTween(notif, TweenInfo.new(0.3), {
                Position = UDim2.new(1, 330, 1, -65),
            })
            task.delay(0.4, function()
                if notif and notif.Parent then notif:Destroy() end
            end)
        end)
    end)
end

