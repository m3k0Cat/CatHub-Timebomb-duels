local ResizeGrip = Instance.new("TextButton")
ResizeGrip.BackgroundTransparency = 1
ResizeGrip.Size = UDim2.new(0, 20, 0, 20)
ResizeGrip.Position = UDim2.new(1, -20, 1, -20)
ResizeGrip.Text = "⋱"
ResizeGrip.TextColor3 = Theme.TextMuted
ResizeGrip.TextSize = 16
ResizeGrip.Font = Theme.FontBold
ResizeGrip.ZIndex = 10
ResizeGrip.AutoButtonColor = false
ResizeGrip.BorderSizePixel = 0
ResizeGrip.Parent = MainFrame

do
    local resizing = false
    local resizeStart, startSize

    ResizeGrip.MouseButton1Down:Connect(function()
        resizing = true
        resizeStart = UserInputService:GetMouseLocation()
        startSize = MainFrame.AbsoluteSize
    end)

    local rm = UserInputService.InputChanged:Connect(function(input)
        if resizing and (input.UserInputType == Enum.UserInputType.MouseMovement
                         or input.UserInputType == Enum.UserInputType.Touch) then
            local mp = UserInputService:GetMouseLocation()
            local delta = mp - resizeStart
            local nw = math.clamp(startSize.X + delta.X, State.MinWindowSize.X, State.MaxWindowSize.X)
            local nh = math.clamp(startSize.Y + delta.Y, State.MinWindowSize.Y, State.MaxWindowSize.Y)
            MainFrame.Size = UDim2.new(0, nw, 0, nh)
            State.WindowSize = MainFrame.Size
            ShadowFrame.Size = UDim2.new(0, nw + 60, 0, nh + 60)
        end
    end)
    table.insert(State.Connections, rm)

    local ru = UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
           or input.UserInputType == Enum.UserInputType.Touch then
            resizing = false
        end
    end)
    table.insert(State.Connections, ru)

    ResizeGrip.MouseEnter:Connect(function()
        SafeTween(ResizeGrip, TweenInfo.new(Theme.AnimSpeedFast), {TextColor3 = Theme.Accent})
    end)
    ResizeGrip.MouseLeave:Connect(function()
        SafeTween(ResizeGrip, TweenInfo.new(Theme.AnimSpeedFast), {TextColor3 = Theme.TextMuted})
    end)
end

