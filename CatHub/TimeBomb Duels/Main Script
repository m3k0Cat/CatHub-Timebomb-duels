local JumpSpoofer = {}

function JumpSpoofer.InitRayParams()
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.RespectCanCollide = true
    pcall(function()
        local char = LocalPlayer.Character
        if char then
            params.FilterDescendantsInstances = {char}
        end
    end)
    State.JumpSpoofer.GroundRayParams = params
end

function JumpSpoofer.IsGrounded()
    local char = LocalPlayer.Character
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    local params = State.JumpSpoofer.GroundRayParams
    if not params then
        JumpSpoofer.InitRayParams()
        params = State.JumpSpoofer.GroundRayParams
    end
    pcall(function() params.FilterDescendantsInstances = {char} end)
    local result = workspace:Raycast(hrp.Position, Vector3.new(0, -4, 0), params)
    return result ~= nil
end

function JumpSpoofer.GetGroundPosition()
    local char = LocalPlayer.Character
    if not char then return nil end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local params = State.JumpSpoofer.GroundRayParams
    if not params then
        JumpSpoofer.InitRayParams()
        params = State.JumpSpoofer.GroundRayParams
    end
    pcall(function() params.FilterDescendantsInstances = {char} end)
    local result = workspace:Raycast(hrp.Position + Vector3.new(0, 2, 0), Vector3.new(0, -50, 0), params)
    if result then
        return result.Position, result.Normal, result.Instance
    end
    return nil
end

function JumpSpoofer.RecordPosition(position)
    local history = State.JumpSpoofer.PositionHistory
    table.insert(history, { Position = position, Time = tick() })
    while #history > State.JumpSpoofer.MaxHistorySize do
        table.remove(history, 1)
    end
end

function JumpSpoofer.SpoofHumanoidState()
    local char = LocalPlayer.Character
    if not char then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    pcall(function()
        humanoid:ChangeState(Enum.HumanoidStateType.Running)
        humanoid:SetStateEnabled(Enum.HumanoidStateType.Freefall, false)
        humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
    end)
end

function JumpSpoofer.RestoreHumanoidState()
    local char = LocalPlayer.Character
    if not char then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    pcall(function()
        humanoid:SetStateEnabled(Enum.HumanoidStateType.Freefall, true)
        humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, true)
        humanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, true)
    end)
end

function JumpSpoofer.SuppressJumpAnimation()
    local char = LocalPlayer.Character
    if not char then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    pcall(function()
        local animator = humanoid:FindFirstChildOfClass("Animator")
        if not animator then return end
        local tracks = animator:GetPlayingAnimationTracks()
        for _, track in ipairs(tracks) do
            local animName = ""
            pcall(function() animName = track.Animation.AnimationId:lower() end)
            pcall(function() animName = animName .. track.Name:lower() end)
            if animName:find("jump") or animName:find("fall") or animName:find("freefall") then
                track:Stop(0)
            end
        end
    end)
end

function JumpSpoofer.ForceGroundAnimation()
    local char = LocalPlayer.Character
    if not char then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    pcall(function()
